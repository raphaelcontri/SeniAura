# CONFIGURATION FIREBASE (Authentification et Firestore)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_DATABASE_URL=https://your_project_id.firebaseio.com

# CONFIGURATION SUPABASE (Stockage Intermédiaire)
SUPABASE_URL=https://your_project_id.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key
SUPABASE_BUCKET_NAME=cardiaura-datasets

# CONFIGURATION DATABRICKS (Facultatif dans l'Option A pour DuckDB, mais utile si besoin)
DATABRICKS_SERVER_HOSTNAME=your_databricks_host.cloud.databricks.com
DATABRICKS_HTTP_PATH=your_databricks_http_path
DATABRICKS_TOKEN=your_databricks_token
